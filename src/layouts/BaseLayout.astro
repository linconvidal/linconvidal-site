---
import '../styles/global.css';
import SocialLinks from '../components/SocialLinks.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Lincon Vidal',
  description = 'Software, photography, games, and notes by Lincon Vidal.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Lincon Vidal" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <script>
      import posthog from 'posthog-js';

      const posthogKey = import.meta.env.PUBLIC_POSTHOG_KEY ?? 'phc_p71MtPmJsasEtaEOgnaoyIMq7gzAA4MDDkNKM6aCLAb';
      const posthogHost = import.meta.env.PUBLIC_POSTHOG_HOST ?? 'https://us.i.posthog.com';
      const isLocalhost = ['localhost', '127.0.0.1', '::1'].includes(window.location.hostname);

      if (posthogKey && !isLocalhost) {
        posthog.init(posthogKey, {
          api_host: posthogHost,
          defaults: '2026-05-30',
          capture_pageview: true,
          capture_pageleave: false,
          autocapture: false,
          rageclick: false,
          capture_dead_clicks: false,
          capture_exceptions: false,
          capture_heatmaps: false,
          capture_performance: false,
          disable_scroll_properties: true,
          disable_session_recording: true,
          person_profiles: 'identified_only',
          respect_dnt: true,
        });
      }
    </script>
  </head>
  <body>
    <header class="site-header">
      <nav class="container nav" aria-label="Main navigation">
        <a href="/" class="brand">Lincon Vidal</a>
        <div class="nav-links">
          <a href="/photography/">photography</a>
          <a href="/software/">software</a>
          <a href="/games/">games</a>
          <a href="/notes/">notes</a>
        </div>
      </nav>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <span>© Lincon Vidal</span>
        <SocialLinks />
      </div>
    </footer>
  </body>
</html>
