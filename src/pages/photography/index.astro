---
import BaseLayout from '../../layouts/BaseLayout.astro';

const photographs = [
  {
    src: '/photographs/home/paraty-street.jpg',
    alt: 'Street in Paraty photographed by Lincon Vidal',
    caption: 'Paraty, 2025',
    orientation: 'portrait',
  },
  {
    src: '/photographs/home/paraty-canal.jpg',
    alt: 'Canal in Paraty photographed by Lincon Vidal',
    caption: 'Paraty, 2025',
    orientation: 'landscape',
  },
  {
    src: '/photographs/home/yellow-door.jpg',
    alt: 'Yellow doorway in Paraty photographed by Lincon Vidal',
    caption: 'Paraty, 2025',
    orientation: 'portrait',
  },
  {
    src: '/photographs/home/boats.jpg',
    alt: 'Boats on the water photographed by Lincon Vidal',
    caption: 'Paraty, 2025',
    orientation: 'landscape',
  },
  {
    src: '/photographs/home/water-texture.jpg',
    alt: 'Water texture photographed by Lincon Vidal',
    caption: 'Paraty, 2025',
    orientation: 'square',
  },
  {
    src: '/photographs/home/mountain.jpg',
    alt: 'Mountain near Paraty photographed by Lincon Vidal',
    caption: 'Paraty, 2025',
    orientation: 'landscape',
  },
];

const formats = [
  {
    title: 'Photo essays',
    description: 'A few photographs that make more sense together than alone.',
  },
  {
    title: 'Zines',
    description: 'Small edits that can sit on a table.',
  },
  {
    title: 'Prints',
    description: 'Photographs I want to see outside the screen.',
  },
];
---

<BaseLayout
  title="Photography · Lincon Vidal"
  description="Photography, photo essays, zines, and selected prints by Lincon Vidal."
>
  <section class="page-hero photography-hero">
    <div>
      <p class="eyebrow">photography</p>
      <h1>Photographs, edits, and small printed things.</h1>
      <p class="lede">
        Photo essays, zines, selected prints, and the archive I keep coming back to.
      </p>
    </div>
    <figure class="hero-polaroid">
      <img src="/photographs/home/yellow-door.jpg" alt="Yellow doorway in Paraty photographed by Lincon Vidal" />
      <figcaption>Paraty, 2025</figcaption>
    </figure>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">selected photographs</p>
      <h2>A small wall.</h2>
    </div>
    <div class="photo-grid">
      {photographs.map((photograph) => (
        <figure class={`photo-tile ${photograph.orientation}`}>
          <img src={photograph.src} alt={photograph.alt} />
          <figcaption>{photograph.caption}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <section class="section split-section">
    <div>
      <p class="eyebrow">formats</p>
      <h2>Where the photographs go.</h2>
    </div>
    <div class="card-grid three-column">
      {formats.map((format) => (
        <article class="feature-card quiet-card">
          <h3>{format.title}</h3>
          <p>{format.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
