---
import BaseLayout from '../../layouts/BaseLayout.astro';

const photographs = [
  {
    src: '/photographs/home/paraty-street.jpg',
    alt: 'Street in Paraty photographed by Lincon Vidal',
    caption: 'Paraty, 2025',
  },
  {
    src: '/photographs/home/paraty-canal.jpg',
    alt: 'Canal in Paraty photographed by Lincon Vidal',
    caption: 'Paraty, 2025',
  },
  {
    src: '/photographs/home/yellow-door.jpg',
    alt: 'Yellow doorway in Paraty photographed by Lincon Vidal',
    caption: 'Paraty, 2025',
  },
  {
    src: '/photographs/home/boats.jpg',
    alt: 'Boats on the water photographed by Lincon Vidal',
    caption: 'Paraty, 2025',
  },
  {
    src: '/photographs/home/water-texture.jpg',
    alt: 'Water texture photographed by Lincon Vidal',
    caption: 'Paraty, 2025',
  },
  {
    src: '/photographs/home/mountain.jpg',
    alt: 'Mountain near Paraty photographed by Lincon Vidal',
    caption: 'Paraty, 2025',
  },
];
---

<BaseLayout
  title="Photography · Lincon Vidal"
  description="Photography by Lincon Vidal."
>
  <section class="page-hero photography-hero">
    <div>
      <p class="eyebrow">photography</p>
      <h1>Photographs from the archive.</h1>
      <p class="lede">
        Photographs I keep coming back to.
      </p>
    </div>
    <figure class="hero-polaroid">
      <img src="/photographs/home/yellow-door.jpg" alt="Yellow doorway in Paraty photographed by Lincon Vidal" />
      <figcaption>Paraty, 2025</figcaption>
    </figure>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">selected photographs</p>
      <h2>Paraty, 2025.</h2>
    </div>
    <div class="photo-grid">
      {photographs.map((photograph) => (
        <figure class="photo-tile">
          <img src={photograph.src} alt={photograph.alt} />
          <figcaption>{photograph.caption}</figcaption>
        </figure>
      ))}
    </div>
  </section>
</BaseLayout>
