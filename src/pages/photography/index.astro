---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhotoGrid from '../../components/PhotoGrid.astro';
import {
  getPhotos,
  getSeries,
  photoUrl,
  placeUrl,
  selectionsByPlaceYear,
  seriesUrl,
  yearUrl,
} from '../../lib/photos';

const photos = await getPhotos();
const selections = selectionsByPlaceYear(photos);
const allSeries = await getSeries();

const heroPhoto = photos.find((photo) => photo.id === 'paraty-yellow-door') ?? photos[0];
---

<BaseLayout
  title="Photography · Lincon Vidal"
  description="Photography by Lincon Vidal."
>
  <section class="page-hero photography-hero">
    <div>
      <p class="eyebrow">photography</p>
      <h1>Photographs I take.</h1>
      <p class="lede">The ones I keep coming back to.</p>
    </div>
    {heroPhoto && (
      <figure class="hero-polaroid">
        <a href={photoUrl(heroPhoto)}>
          <img src={heroPhoto.data.src} alt={heroPhoto.data.alt} />
        </a>
        <figcaption>{heroPhoto.data.place.title}, {heroPhoto.data.year}</figcaption>
      </figure>
    )}
  </section>

  {selections.map((selection) => (
    <section class="section">
      <div class="section-heading">
        <h2 class="selection-title">
          <a href={placeUrl(selection.place.slug)}>{selection.place.title}</a>,{' '}
          <a href={yearUrl(selection.year)}>{selection.year}</a>
        </h2>
      </div>
      <PhotoGrid photos={selection.photos} />
    </section>
  ))}

  {allSeries.length > 0 && (
    <section class="section">
      <div class="section-heading">
        <h2>Series.</h2>
      </div>
      <div class="note-list expanded-list">
        {allSeries.map((series) => (
          <a class="note-row expanded-row" href={seriesUrl(series)}>
            <span class="note-date">{series.data.photos.length} photographs</span>
            <span>
              <strong>{series.data.title}</strong>
              {series.data.description && <small>{series.data.description}</small>}
            </span>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
