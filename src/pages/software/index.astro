---
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'Cobogó',
    description: 'A spatial markdown thing. It started as a renderer and got a little out of hand.',
  },
  {
    title: 'Farol',
    description: 'A Cardano wallet I’m making because I wanted something quieter.',
  },
  {
    title: 'SpatialMD',
    description: 'A way to write diagrams and visual notes without opening a design tool.',
  },
];

---

<BaseLayout
  title="Software · Lincon Vidal"
  description="Software by Lincon Vidal."
>
  <section class="page-hero compact-hero">
    <p class="eyebrow">software</p>
    <h1>Software I keep around.</h1>
    <p class="lede">
      Some of it is public. Some of it is just how I organize my own work.
    </p>
  </section>

  <section class="section split-section">
    <div>
      <p class="eyebrow">things</p>
      <h2>A few things.</h2>
    </div>
    <div class="card-grid three-column">
      {projects.map((project) => (
        <article class="feature-card quiet-card">
          <h3>{project.title}</h3>
          <p>{project.description}</p>
        </article>
      ))}
    </div>
  </section>

</BaseLayout>
