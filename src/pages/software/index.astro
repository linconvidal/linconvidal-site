---
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'Cobogó',
    description: 'Spatial markdown. It started as a renderer, then the files stopped feeling like a list.',
  },
  {
    title: 'Farol',
    description: 'A Cardano wallet that tries to stay quiet until something actually needs attention.',
  },
  {
    title: 'SpatialMD',
    description: 'Markdown blocks for diagrams, comparisons, and visual explanations.',
  },
];

---

<BaseLayout
  title="Software · Lincon Vidal"
  description="Software by Lincon Vidal."
>
  <section class="page-hero compact-hero">
    <p class="eyebrow">software</p>
    <h1>Cobogó, Farol, SpatialMD.</h1>
    <p class="lede">
      Three software projects I keep returning to.
    </p>
  </section>

  <section class="section">
    <div class="card-grid three-column">
      {projects.map((project) => (
        <article class="feature-card quiet-card">
          <h3>{project.title}</h3>
          <p>{project.description}</p>
        </article>
      ))}
    </div>
  </section>

</BaseLayout>
