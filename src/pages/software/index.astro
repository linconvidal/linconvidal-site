---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkTimeline from '../../components/WorkTimeline.astro';
import { getCollection } from 'astro:content';

const software = (await getCollection('work')).filter((entry) => entry.data.kind === 'software');
---

<BaseLayout
  title="Software · Lincon Vidal"
  description="Software by Lincon Vidal."
>
  <section class="page-hero compact-hero">
    <p class="eyebrow">software</p>
    <h1>Things I build.</h1>
    <p class="lede">Software I keep returning to: tools, experiments, infrastructure, interfaces, and this site itself.</p>
  </section>

  <WorkTimeline entries={software} showKindKey={false} />
</BaseLayout>
