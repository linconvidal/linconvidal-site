---
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'Cobogó',
    description: 'Spatial documents and visual notes. It started as a markdown renderer and got a little out of hand.',
    meta: 'product',
  },
  {
    title: 'Farol Wallet',
    description: 'A Cardano wallet I am building for desktop and mobile.',
    meta: 'wallet',
  },
  {
    title: 'SpatialMD',
    description: 'Markdown with layout blocks for guides, comparisons, flows, and visual explanations.',
    meta: 'format',
  },
  {
    title: 'Infrastructure work',
    description: 'Cardano integrations, release notes, test plans, and the glue work around shipping.',
    meta: 'systems',
  },
];

---

<BaseLayout
  title="Software · Lincon Vidal"
  description="Software projects, tools, and systems by Lincon Vidal."
>
  <section class="page-hero compact-hero">
    <p class="eyebrow">software</p>
    <h1>Software I’m building and maintaining.</h1>
    <p class="lede">
      Wallets, publishing tools, docs, infrastructure, and small things that came out of my own work.
    </p>
  </section>

  <section class="section split-section">
    <div>
      <p class="eyebrow">current work</p>
      <h2>Current projects.</h2>
    </div>
    <div class="card-grid two-column">
      {projects.map((project) => (
        <article class="feature-card">
          <p class="card-meta">{project.meta}</p>
          <h3>{project.title}</h3>
          <p>{project.description}</p>
        </article>
      ))}
    </div>
  </section>

</BaseLayout>
