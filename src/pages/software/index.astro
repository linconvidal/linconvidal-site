---
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'Cobogó',
    description: 'Spatial markdown. It started as a renderer, then the files stopped feeling like a list.',
    status: 'in progress · not public yet',
  },
  {
    title: 'Farol',
    description: 'A Cardano wallet that tries to stay quiet until something actually needs attention.',
    status: 'testnet only · not public yet',
  },
];

---

<BaseLayout
  title="Software · Lincon Vidal"
  description="Software by Lincon Vidal."
>
  <section class="page-hero compact-hero">
    <p class="eyebrow">software</p>
    <h1>Things I build.</h1>
    <p class="lede">
      Software projects I keep returning to. Right now that’s Cobogó
      and Farol.
    </p>
  </section>

  <section class="section">
    <div class="card-grid two-column">
      {projects.map((project) => (
        <article class="feature-card quiet-card">
          <p class="card-meta">{project.status}</p>
          <h3>{project.title}</h3>
          <p>{project.description}</p>
        </article>
      ))}
    </div>
  </section>

</BaseLayout>
