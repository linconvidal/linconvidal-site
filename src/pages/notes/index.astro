---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes'))
  .filter((note) => !note.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<BaseLayout
  title="Notes · Lincon Vidal"
  description="Notes by Lincon Vidal."
>
  <section class="page-hero compact-hero">
    <p class="eyebrow">notes</p>
    <h1>Notes.</h1>
    <p class="lede">
      Things I want to leave somewhere more stable than a chat or a timeline.
    </p>
  </section>

  <section class="section notes-index simple-notes-index">
    <div class="note-list expanded-list">
      {notes.map((note) => (
        <a class="note-row expanded-row" href={`/notes/${note.id}/`}>
          <span class="note-date">{note.data.publishedAt.toISOString().slice(0, 10)}</span>
          <span>
            <strong>{note.data.title}</strong>
            {note.data.description && <small>{note.data.description}</small>}
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
