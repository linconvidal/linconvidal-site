---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes'))
  .filter((note) => !note.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

const homePhotographs = [
  {
    src: '/photographs/home/paraty-street.jpg',
    alt: 'Street in Paraty photographed by Lincon Vidal',
    caption: 'Paraty, 2025',
  },
  {
    src: '/photographs/home/paraty-canal.jpg',
    alt: 'Canal in Paraty photographed by Lincon Vidal',
    caption: 'Paraty, 2025',
  },
  {
    src: '/photographs/home/yellow-door.jpg',
    alt: 'Yellow doorway in Paraty photographed by Lincon Vidal',
    caption: 'Paraty, 2025',
  },
  {
    src: '/photographs/home/boats.jpg',
    alt: 'Boats on the water photographed by Lincon Vidal',
    caption: 'Paraty, 2025',
  },
  {
    src: '/photographs/home/water-texture.jpg',
    alt: 'Water texture photographed by Lincon Vidal',
    caption: 'Paraty, 2025',
  },
  {
    src: '/photographs/home/mountain.jpg',
    alt: 'Mountain near Paraty photographed by Lincon Vidal',
    caption: 'Paraty, 2025',
  },
];
---

<BaseLayout>
  <section class="front-hero">
    <div class="front-intro">
      <h1>Software, photography, games, notes.</h1>
      <p class="lede">A small site for photographs, software, games, and notes.</p>
    </div>

    <div class="front-list" aria-label="Main sections">
      <a class="front-link" href="/software">
        <span class="front-number">01</span>
        <strong>Software</strong>
        <span>Cobogó, Farol, SpatialMD.</span>
      </a>
      <a class="front-link" href="/photography">
        <span class="front-number">02</span>
        <strong>Photography</strong>
        <span>Photographs and edits.</span>
      </a>
      <a class="front-link" href="/games">
        <span class="front-number">03</span>
        <strong>Games</strong>
        <span>Pinote.</span>
      </a>
      <a class="front-link" href="/notes">
        <span class="front-number">04</span>
        <strong>Notes</strong>
        <span>Writing worth keeping around.</span>
      </a>
    </div>

    <figure class="front-photo" data-photo-rotator>
      <img
        data-photograph
        src={homePhotographs[0].src}
        alt={homePhotographs[0].alt}
      />
      <figcaption>
        <span data-photo-caption>{homePhotographs[0].caption}</span>
        <button type="button" data-next-photo>another photograph</button>
      </figcaption>
    </figure>
  </section>

  <section class="section notes-section">
    <div>
      <p class="eyebrow">notes</p>
      <h2>Recent notes</h2>
    </div>
    <div class="note-list">
      {notes.map((note) => (
        <a class="note-row" href={`/notes/${note.id}`}>
          <span class="note-date">{note.data.publishedAt.toISOString().slice(0, 10)}</span>
          <span>{note.data.title}</span>
        </a>
      ))}
    </div>
  </section>

  <script is:inline type="application/json" id="home-photographs" set:html={JSON.stringify(homePhotographs)} />
  <script is:inline>
    const data = document.getElementById('home-photographs')?.textContent ?? '[]';
    const photographs = JSON.parse(data);
    const root = document.querySelector('[data-photo-rotator]');
    const photographNode = root?.querySelector('[data-photograph]');
    const caption = root?.querySelector('[data-photo-caption]');
    const button = root?.querySelector('[data-next-photo]');

    let index = 0;

    button?.addEventListener('click', () => {
      if (!photographNode || !caption || photographs.length < 2) return;

      let next = Math.floor(Math.random() * photographs.length);
      if (next === index) next = (next + 1) % photographs.length;
      index = next;

      const photograph = photographs[index];
      photographNode.src = photograph.src;
      photographNode.alt = photograph.alt;
      caption.textContent = photograph.caption;
    });
  </script>
</BaseLayout>
