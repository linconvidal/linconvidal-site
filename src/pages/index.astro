---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes'))
  .filter((note) => !note.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <section class="home-hero">
    <div class="hero-copy">
      <p class="eyebrow">linconvidal.com · static studio</p>
      <h1>Code, images, games, notes.</h1>
      <p class="lede">
        A personal site for things made with attention: software projects, visual work,
        small games, and essays that need more room than a feed gives them.
      </p>
      <div class="pill-row" aria-label="Site themes">
        <span class="pill">Cobogó</span>
        <span class="pill">Pinote</span>
        <span class="pill">prints</span>
        <span class="pill">devlogs</span>
      </div>
    </div>

    <aside class="studio-index" aria-label="Site index card">
      <div class="index-topline">
        <span>LV / 0001</span>
        <span>static</span>
      </div>
      <div class="index-mark">LV</div>
      <dl class="index-list">
        <div><dt>build</dt><dd>software tools</dd></div>
        <div><dt>see</dt><dd>photo essays</dd></div>
        <div><dt>play</dt><dd>Pinote</dd></div>
        <div><dt>write</dt><dd>notes / essays</dd></div>
      </dl>
      <p class="stamp">not a feed</p>
    </aside>
  </section>

  <section class="path-grid" aria-label="Site sections">
    <a class="path-card path-card--visuals" href="/visuals">
      <span class="number">01</span>
      <div>
        <h3>Visuals</h3>
        <p>Photo essays, zines, and future print editions. Not a stock gallery.</p>
      </div>
    </a>
    <a class="path-card path-card--software" href="/software">
      <span class="number">02</span>
      <div>
        <h3>Software</h3>
        <p>Cobogó, Farol, SpatialMD, Cardano tooling, and experiments that became useful.</p>
      </div>
    </a>
    <a class="path-card path-card--games" href="/games">
      <span class="number">03</span>
      <div>
        <h3>Games</h3>
        <p>Pinote, Cotinga Games, motorcycles, systems, prototypes, and devlogs.</p>
      </div>
    </a>
    <a class="path-card path-card--notes" href="/notes">
      <span class="number">04</span>
      <div>
        <h3>Notes</h3>
        <p>Essays, public drafts, release notes, and the writing that keeps projects alive.</p>
      </div>
    </a>
  </section>

  <section class="section notes-section">
    <div>
      <p class="eyebrow">notes / essays</p>
      <h2>Recent writing</h2>
    </div>
    <div class="note-list">
      {notes.map((note) => (
        <a class="note-row" href={`/notes/${note.id}`}>
          <span class="note-date">{note.data.publishedAt.toISOString().slice(0, 10)}</span>
          <span>{note.data.title}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
