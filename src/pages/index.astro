---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes'))
  .filter((note) => !note.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <section class="home-hero">
    <div class="hero-copy">
      <p class="eyebrow">linconvidal.com · selected work</p>
      <h1>Code, photographs, games, notes.</h1>
      <p class="lede">
        Software tools, visual work, game projects, and writing from the same practice.
      </p>
      <div class="pill-row" aria-label="Site themes">
        <span class="pill">Cobogó</span>
        <span class="pill">Pinote</span>
        <span class="pill">prints</span>
        <span class="pill">essays</span>
      </div>
    </div>

    <aside class="studio-index" aria-label="Work index card">
      <div class="index-topline">
        <span>LV / 0001</span>
        <span>index</span>
      </div>
      <div class="index-mark">LV</div>
      <dl class="index-list">
        <div><dt>code</dt><dd>software tools</dd></div>
        <div><dt>photo</dt><dd>photography</dd></div>
        <div><dt>game</dt><dd>Pinote</dd></div>
        <div><dt>note</dt><dd>essays</dd></div>
      </dl>
      <p class="stamp">selected work</p>
    </aside>
  </section>

  <section class="path-grid" aria-label="Site sections">
    <a class="path-card path-card--visuals" href="/visuals">
      <span class="number">01</span>
      <div>
        <h3>Visuals</h3>
        <p>Photo essays, zines, and selected prints.</p>
      </div>
    </a>
    <a class="path-card path-card--software" href="/software">
      <span class="number">02</span>
      <div>
        <h3>Software</h3>
        <p>Cobogó, Farol, SpatialMD, Cardano tooling, and focused experiments.</p>
      </div>
    </a>
    <a class="path-card path-card--games" href="/games">
      <span class="number">03</span>
      <div>
        <h3>Games</h3>
        <p>Pinote, Cotinga Games, motorcycles, systems, prototypes, and devlogs.</p>
      </div>
    </a>
    <a class="path-card path-card--notes" href="/notes">
      <span class="number">04</span>
      <div>
        <h3>Notes</h3>
        <p>Essays, devlogs, field notes, and public fragments.</p>
      </div>
    </a>
  </section>

  <section class="section notes-section">
    <div>
      <p class="eyebrow">notes / essays</p>
      <h2>Recent writing</h2>
    </div>
    <div class="note-list">
      {notes.map((note) => (
        <a class="note-row" href={`/notes/${note.id}`}>
          <span class="note-date">{note.data.publishedAt.toISOString().slice(0, 10)}</span>
          <span>{note.data.title}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
