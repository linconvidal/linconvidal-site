---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getPhotos } from '../lib/photos';

const notes = (await getCollection('notes'))
  .filter((note) => !note.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

const homePhotographs = (await getPhotos()).map((photo) => ({
  src: photo.data.src,
  alt: photo.data.alt,
  caption: `${photo.data.place.title}, ${photo.data.year}`,
}));
---

<BaseLayout>
  <section class="front-hero">
    <h1 class="front-opening">Things I made and want to keep in one place.</h1>

    <div class="front-list" aria-label="Main sections">
      <a class="front-link" href="/photography/">
        <span class="front-icon" aria-hidden="true">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="square">
            <rect x="1.5" y="1.5" width="13" height="13" />
            <circle cx="8" cy="8" r="3.5" />
          </svg>
        </span>
        <strong>Photography</strong>
        <span>Images I keep coming back to.</span>
      </a>
      <a class="front-link" href="/software/">
        <span class="front-icon" aria-hidden="true">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="square">
            <polyline points="2.5 4 6.5 8 2.5 12" />
            <line x1="8.5" y1="12.5" x2="13.5" y2="12.5" />
          </svg>
        </span>
        <strong>Software</strong>
        <span>Tools I'm building for myself.</span>
      </a>
      <a class="front-link" href="/games/">
        <span class="front-icon" aria-hidden="true">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="square">
            <rect x="1.5" y="1.5" width="13" height="13" rx="2.5" />
            <circle cx="5.1" cy="5.1" r="1.15" fill="currentColor" stroke="none" />
            <circle cx="8" cy="8" r="1.15" fill="currentColor" stroke="none" />
            <circle cx="10.9" cy="10.9" r="1.15" fill="currentColor" stroke="none" />
          </svg>
        </span>
        <strong>Games</strong>
        <span>Small systems made for play.</span>
      </a>
      <a class="front-link" href="/notes/">
        <span class="front-icon" aria-hidden="true">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="square">
            <line x1="2" y1="4" x2="14" y2="4" />
            <line x1="2" y1="8" x2="14" y2="8" />
            <line x1="2" y1="12" x2="9" y2="12" />
          </svg>
        </span>
        <strong>Notes</strong>
        <span>Writing and decisions worth keeping.</span>
      </a>
    </div>
  </section>

  <section class="front-photo-band">
    <figure class="front-photo" data-photo-rotator>
      <img
        data-photograph
        src={homePhotographs[0].src}
        alt={homePhotographs[0].alt}
      />
      <figcaption>
        <span data-photo-caption>{homePhotographs[0].caption}</span>
        <button type="button" data-next-photo>another photograph</button>
      </figcaption>
    </figure>
  </section>

  <section class="front-notes">
    <h2 class="front-notes-title">Recent notes</h2>
    <div class="front-note-flow">
      {notes.map((note) => (
        <a class="front-note" href={`/notes/${note.id}/`}>
          <span class="front-note-heading">{note.data.title}</span>
          <time class="front-note-date" datetime={note.data.publishedAt.toISOString().slice(0, 10)}>
            {note.data.publishedAt.toISOString().slice(0, 10)}
          </time>
        </a>
      ))}
    </div>
  </section>

  <script is:inline type="application/json" id="home-photographs" set:html={JSON.stringify(homePhotographs)} />
  <script is:inline>
    const data = document.getElementById('home-photographs')?.textContent ?? '[]';
    const photographs = JSON.parse(data);
    const root = document.querySelector('[data-photo-rotator]');
    const photographNode = root?.querySelector('[data-photograph]');
    const caption = root?.querySelector('[data-photo-caption]');
    const button = root?.querySelector('[data-next-photo]');

    let index = 0;

    button?.addEventListener('click', () => {
      if (!photographNode || !caption || photographs.length < 2) return;

      let next = Math.floor(Math.random() * photographs.length);
      if (next === index) next = (next + 1) % photographs.length;
      index = next;

      const photograph = photographs[index];
      photographNode.src = photograph.src;
      photographNode.alt = photograph.alt;
      caption.textContent = photograph.caption;
    });
  </script>
</BaseLayout>
