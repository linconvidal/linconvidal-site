---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkTimeline from '../../components/WorkTimeline.astro';
import { getCollection } from 'astro:content';

const games = (await getCollection('work')).filter((entry) => entry.data.kind === 'game');
---

<BaseLayout
  title="Games · Lincon Vidal"
  description="Games by Lincon Vidal."
>
  <section class="page-hero compact-hero games-hero">
    <p class="eyebrow">games</p>
    <h1>Games I make.</h1>
    <p class="lede">Little worlds, physics toys, simulations, and unfinished games.</p>
  </section>

  <WorkTimeline entries={games} showKindKey={false} />
</BaseLayout>
