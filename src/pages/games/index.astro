---
import BaseLayout from '../../layouts/BaseLayout.astro';

const gameWork = [
  {
    title: 'Pinote',
    description: 'A small bike game about timing, weight, and bad landings.',
    meta: 'active',
  },
  {
    title: 'Prototypes',
    description: 'One-mechanic tests before anything becomes a bigger project.',
    meta: 'experiments',
  },
  {
    title: 'Devlogs',
    description: 'Notes on feel, movement, difficulty, and what changed.',
    meta: 'writing',
  },
];

const questions = [
  'Can I understand the crash?',
  'Does it feel good before it has content?',
  'Can the screen explain itself without stopping the game?',
];
---

<BaseLayout
  title="Games · Lincon Vidal"
  description="Games, prototypes, and devlogs by Lincon Vidal."
>
  <section class="page-hero compact-hero games-hero">
    <p class="eyebrow">games</p>
    <h1>Games I’m making. Mostly Pinote for now.</h1>
    <p class="lede">
      Pinote, small prototypes, and notes about game feel.
    </p>
  </section>

  <section class="section split-section">
    <div>
      <p class="eyebrow">workbench</p>
      <h2>Current game work.</h2>
    </div>
    <div class="card-grid three-column">
      {gameWork.map((item) => (
        <article class="feature-card">
          <p class="card-meta">{item.meta}</p>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section split-section">
    <div>
      <p class="eyebrow">questions</p>
      <h2>The checks are simple.</h2>
    </div>
    <ol class="rule-list">
      {questions.map((question) => <li>{question}</li>)}
    </ol>
  </section>
</BaseLayout>
